<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- App theme — uses Material3 (DayNight), the actual surface colors come
         from the Compose theme. The window background is transparent dark so
         the edge-to-edge gradient in Compose draws correctly. -->
    <style name="Theme.GlassCalculator" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>

<?xml version="1.0" encoding="utf-8"?>
<!-- Foreground layer of the adaptive launcher icon. Adaptive icons are
     108x108dp but only the central 66x66dp is guaranteed visible across
     launcher masks (the rest gets cropped). We center an "=" glyph here. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Top bar of equals -->
    <path
        android:pathData="M36,48 L72,48 A4,4 0 0,1 76,52 L76,56 A4,4 0 0,1 72,60 L36,60 A4,4 0 0,1 32,56 L32,52 A4,4 0 0,1 36,48 Z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.95" />
    <!-- Bottom bar of equals -->
    <path
        android:pathData="M36,66 L72,66 A4,4 0 0,1 76,70 L76,74 A4,4 0 0,1 72,78 L36,78 A4,4 0 0,1 32,74 L32,70 A4,4 0 0,1 36,66 Z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.95" />
</vector>
